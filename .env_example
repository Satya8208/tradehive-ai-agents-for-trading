# TradeHive AI Agents environment template
#
# Copy this file to .env for local use. Keep real values only in .env.
# Never commit real API keys, wallet keys, bearer tokens, cookies, or private RPC URLs.

# Trading APIs
BIRDEYE_API_KEY=your_birdeye_api_key_here
RPC_ENDPOINT=your_solana_rpc_endpoint_here
TRADEHIVE_API_KEY=your_tradehive_api_key_here
TRADEHIVE_API_BASE_URL=http://localhost:8000
COINGECKO_API_KEY=your_coingecko_api_key_here

# Blockchain / exchange keys
SOLANA_PRIVATE_KEY=your_base58_solana_private_key_here
HYPER_LIQUID_KEY=your_hyperliquid_key_here
HYPER_LIQUID_ETH_PRIVATE_KEY=your_hyperliquid_eth_private_key_here
ASTER_API_KEY=your_aster_api_key_here
ASTER_API_SECRET=your_aster_api_secret_here
USE_TESTNET=false

# Extended / X10 exchange
X10_API_KEY=your_x10_api_key_here
X10_PRIVATE_KEY=your_x10_private_key_here
X10_VAULT_ID=your_x10_vault_id_here
X10_PUBLIC_KEY=your_x10_public_key_here

# AI service keys
ANTHROPIC_KEY=your_anthropic_key_here
OPENAI_KEY=your_openai_key_here
DEEPSEEK_KEY=your_deepseek_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
GROQ_API_KEY=your_groq_key_here
GROK_API_KEY=your_xai_grok_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# Media / social integrations
YOUTUBE_API_KEY=your_youtube_api_key_here
RESTREAM_CLIENT_ID=your_restream_client_id_here
RESTREAM_CLIENT_SECRET=your_restream_client_secret_here
RESTREAM_EMBED_TOKEN=your_restream_embed_token_here
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWITTER_USERNAME=your_twitter_username_here
TWITTER_EMAIL=your_twitter_email_here
TWITTER_PASSWORD=your_twitter_password_here
GOOGLE_APPLICATION_CREDENTIALS=your_google_credentials_path_here

# Polymarket live trading credentials
POLYMARKET_PRIVATE_KEY=your_polymarket_private_key_here
POLYMARKET_FUNDER_ADDRESS=your_polymarket_funder_address_here

# Security reminders
# 1. Keep .env local and ignored.
# 2. Use placeholders only in this template.
# 3. Rotate keys immediately if a real value is committed or shared.
